PROJECT_NAME="Production AI/Backend API"

# Database Secrets (Placeholders for other developers)
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=your_production_db

# Assembled URLs for FastAPI to consume
DATABASE_URL=postgresql://your_postgres_user:your_secure_password@db:5432/your_production_db
REDIS_URL=redis://redis:6379/0
